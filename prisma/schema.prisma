// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Player {
  usenname  String @id
  password  String
  highScore Int
}

model Scores {
  id         String   @id
  topPlayers String[]
  topScores  Int[]
}
